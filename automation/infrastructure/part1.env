# Part 1 automation configuration
# Override any value by exporting env vars before running the script.

CLUSTER_NAME="part1.k8s.local"
PART1_CONFIG_FILE="part1.yaml"
KOPS_STATE_STORE="gs://cca-eth-2026-group-059-dgobbetti"
KOPS_ADMIN_TTL="87600h"
KOPS_WAIT_DURATION="10m"

BOOTSTRAP_SCRIPT="automation/bootstrap/bootstrap_part1_services.sh"

# Kubernetes resources for Part 1
MEMCACHED_MANIFEST="memcache-t1-cpuset.yaml"
INTERFERENCE_MANIFEST="interference/ibench-cpu.yaml"
MEMCACHED_SERVICE_NAME="some-memcached-11211"

# Bootstrap behavior
BOOTSTRAP_INSTALL_MCPERF_ON_MEASURE="true"
START_MCPERF_AGENT="true"
MCPERF_AGENT_THREADS="16"

# SSH behavior
SSH_USER="ubuntu"
SSH_KEY_FILE="$HOME/.ssh/id_ed25519"
GCE_ZONE="europe-west1-b"
